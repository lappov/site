    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-8 right-8 bg-[#1f222b] border border-green-500/30 text-white px-6 py-4 rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,0.5)] flex items-center gap-4 transform translate-y-24 opacity-0 pointer-events-none transition-all duration-500 cubic-bezier(0.68, -0.55, 0.265, 1.55) z-[200]">
        <div class="w-10 h-10 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center shrink-0"><i class="fa-solid fa-check text-lg"></i></div>
        <div>
            <div class="font-display font-bold text-sm text-white">УСПЕШНО!</div>
            <div class="text-xs text-gray-400">IP скопирован в буфер обмена</div>
        </div>
    </div>

    <script>
        // --- ПРЕЛОАДЕР И АКТИВНОЕ МЕНЮ ---
        window.addEventListener('load', () => {
            const preloader = document.getElementById('preloader');
            preloader.classList.add('opacity-0');
            setTimeout(() => preloader.style.display = 'none', 500);
        });

        document.addEventListener("DOMContentLoaded", () => {
            const currentPath = window.location.pathname.split('/').pop() || 'index.html';
            document.querySelectorAll('.nav-links a').forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('text-brand-red', 'drop-shadow-[0_0_8px_rgba(255,46,67,0.5)]');
                    link.classList.remove('text-gray-400', 'hover:text-white');
                }
            });
            document.querySelectorAll('.mobile-nav-links a').forEach(link => {
                if (link.getAttribute('href') === currentPath && !link.classList.contains('text-yellow-500')) {
                    link.classList.add('text-brand-red', 'text-3xl');
                    link.classList.remove('text-white', 'text-2xl');
                }
            });
        });

        const ip = "redoku.bisquit.host";

        function copyIp() {
            navigator.clipboard.writeText(ip).then(() => {
                showToast();
                const textNav = document.getElementById('ip-text-nav');
                const iconNav = document.getElementById('ip-icon-nav');
                if(textNav) {
                    textNav.innerText = "СКОПИРОВАНО!";
                    textNav.classList.add('text-green-400');
                    iconNav.className = "fa-solid fa-check text-green-400";
                    setTimeout(() => {
                        textNav.innerText = ip;
                        textNav.classList.remove('text-green-400');
                        iconNav.className = "fa-regular fa-copy opacity-50 text-xs";
                    }, 3000);
                }
            });
        }

        function copyIpStep4() {
            navigator.clipboard.writeText(ip).then(() => {
                showToast();
                const btn = document.getElementById('btn-copy-step4');
                const text = document.getElementById('text-copy-step4');
                const icon = document.getElementById('icon-copy-step4');
                text.innerText = "СКОПИРОВАНО!";
                icon.className = "fa-solid fa-check";
                btn.classList.remove('bg-white', 'text-black', 'hover:bg-gray-200');
                btn.classList.add('bg-green-500', 'text-white', 'hover:bg-green-600');
                setTimeout(() => {
                    text.innerText = "СКОПИРОВАТЬ";
                    icon.className = "fa-regular fa-copy";
                    btn.classList.add('bg-white', 'text-black', 'hover:bg-gray-200');
                    btn.classList.remove('bg-green-500', 'text-white', 'hover:bg-green-600');
                }, 3000);
            });
        }

        function showToast() {
            const toast = document.getElementById('toast');
            toast.classList.remove('translate-y-24', 'opacity-0');
            setTimeout(() => { toast.classList.add('translate-y-24', 'opacity-0'); }, 3000);
        }

        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu');
            const icon = document.getElementById('mobile-menu-icon');
            if (menu.classList.contains('opacity-0')) {
                menu.classList.remove('opacity-0', 'pointer-events-none');
                menu.classList.add('opacity-100', 'pointer-events-auto');
                icon.className = 'fa-solid fa-xmark text-2xl'; document.body.style.overflow = 'hidden';
            } else {
                menu.classList.add('opacity-0', 'pointer-events-none');
                menu.classList.remove('opacity-100', 'pointer-events-auto');
                icon.className = 'fa-solid fa-bars text-2xl'; document.body.style.overflow = '';
            }
        }

        document.querySelectorAll('.spotlight-card').forEach(card => {
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
                card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
            });
        });

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            if (window.scrollY > 20) { nav.classList.add('shadow-lg'); nav.style.background = 'rgba(15, 17, 22, 0.85)'; } 
            else { nav.classList.remove('shadow-lg'); nav.style.background = 'rgba(15, 17, 22, 0.7)'; }
        });

        // Timeline toggle function
        function toggleTimeline(card) {
            const content = card.querySelector('.timeline-content');
            const icon = card.querySelector('.faq-icon');
            const isOpen = content.classList.contains('open');
            const progress = document.getElementById('timeline-progress');
            
            // Close all other timeline cards
            document.querySelectorAll('.timeline-card').forEach(c => {
                c.classList.remove('active');
                c.querySelector('.timeline-content').classList.remove('open');
                c.querySelector('.faq-icon').style.transform = 'rotate(0deg)';
            });
            
            // Toggle current card
            if (!isOpen) {
                card.classList.add('active');
                content.classList.add('open');
                icon.style.transform = 'rotate(180deg)';
                
                // Update progress based on opened step
                const step = card.closest('.timeline-item').dataset.step;
                const progressValue = step * 25; // 4 steps = 25% each
                progress.style.height = progressValue + '%';
            } else {
                // Reset progress when closing
                progress.style.height = '0%';
            }
        }

        // FAQ toggle function
        function toggleFaq(item) {
            const answer = item.querySelector('.faq-answer');
            const isOpen = item.classList.contains('open');
            
            // Close all other FAQ items
            document.querySelectorAll('.faq-item').forEach(i => {
                i.classList.remove('open');
                i.querySelector('.faq-answer').classList.remove('open');
            });
            
            // Toggle current item
            if (!isOpen) {
                item.classList.add('open');
                answer.classList.add('open');
            }
        }
    </script>
